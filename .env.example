# Resend（お問い合わせフォームのメール送信）
# https://resend.com でアカウント作成 → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# フォーム送信先メールアドレス（店舗のメールアドレス）
CONTACT_EMAIL=info@your-shop.com

# 送信元メールアドレス（Resendで認証済みドメインのアドレス）
# 未設定の場合は noreply@resend.dev になります（テスト用）
# 本番環境では認証済みドメインのアドレスを設定してください
CONTACT_FROM_EMAIL=noreply@your-shop.com

# サイトURL（canonical URL・sitemap.xml に使用）
# 末尾スラッシュなし
NUXT_PUBLIC_SITE_URL=https://your-shop.com
